rules_version = '2';
service cloud.firestore {
  match /databases/{database}/documents {
    // Helper functions
    function isSignedIn() {
      return request.auth != null;
    }
    function isOwner(uid) {
      return isSignedIn() && request.auth.uid == uid;
    }
    function isValidUsername(username) {
      return username.size() >= 3 && username.size() <= 15 && username.matches('^[a-zA-Z0-9_]+$');
    }
    // Check if current user is friends with target user
    function isFriend(targetUid) {
      return isSignedIn() && exists(/databases/$(database)/documents/users/$(request.auth.uid)/friends/$(targetUid));
    }

    // User profiles and basic data
    match /users/{uid} {
      allow read: if isSignedIn(); // Allow reading profiles for social features
      // Validate username format on write (defense-in-depth)
      allow write: if isOwner(uid) && 
        (!request.resource.data.keys().hasAny(['username']) || 
         isValidUsername(request.resource.data.username));

      // Drinks - owner can do anything, friends can read
      match /drinks/{drinkId} {
        allow read: if isOwner(uid) || isFriend(uid);
        // Allow create if Owner OR if Friend AND the creatorId matches the authenticated user (Tagging)
        allow create: if isOwner(uid) || (isFriend(uid) && request.resource.data.creatorId == request.auth.uid);
        // Allow update/delete if Owner OR if the creatorId matches the authenticated user (Tagging)
        // Allow update if Owner 
        // OR if Creator (Tagging)
        // OR if Friend updating social stats/reactions only
        allow update: if isOwner(uid) 
                      || (isFriend(uid) && resource.data.creatorId == request.auth.uid)
                      || (isFriend(uid) && request.resource.data.diff(resource.data).affectedKeys().hasOnly(['reactions', 'commentCount', 'lastCommenterId', 'lastCommentTimestamp']));
        
        allow delete: if isOwner(uid) || (isFriend(uid) && resource.data.creatorId == request.auth.uid);
        
        // Reactions subcollection - friends can add/remove their own reactions
        match /reactions/{reactionId} {
          allow read: if isOwner(uid) || isFriend(uid);
          allow create, update: if isFriend(uid) && request.auth.uid == reactionId;
          allow delete: if request.auth.uid == reactionId;
        }
        
        // Comments subcollection - friends can add, delete only own
        match /comments/{commentId} {
          allow read: if isOwner(uid) || isFriend(uid);
          // Enforce that the comment's uid matches the authenticated user
          allow create: if isFriend(uid) && request.resource.data.uid == request.auth.uid;
          allow delete: if request.auth.uid == resource.data.uid;
        }
      }

      match /notifications/{notifId} {
        allow read, delete: if isOwner(uid);
        // Social notifications (drink tags, comments): the sender must identify
        // themselves truthfully (fromUid) so recipients can't be spoofed/spammed
        // by arbitrary accounts pretending to be someone else.
        allow create: if isSignedIn()
                      && request.resource.data.fromUid == request.auth.uid
                      && request.resource.data.message is string
                      && request.resource.data.message.size() <= 500;
      }

      match /friendRequests/{senderId} {
        allow read, delete: if isOwner(uid);
        allow create: if isSignedIn() && request.auth.uid == senderId;
      }

      match /friends/{friendId} {
        allow read: if isOwner(uid);
        // Acceptance writes to both sides.
        // 1. Owner can write anything to their list.
        // 2. Friend (friendId) can write THEMSELVES to owner's list ONLY IF owner sent them a request.
        allow write: if isOwner(uid) || (
          isSignedIn() && 
          request.auth.uid == friendId && 
          exists(/databases/$(database)/documents/users/$(request.auth.uid)/friendRequests/$(uid))
        );
      }
    }

    // Global username registry to enforce uniqueness
    match /usernames/{username} {
      allow read: if true;
      // A user may only reserve a username FOR THEMSELVES (uid must match),
      // and may only update/release reservations they own.
      allow create: if isSignedIn()
                    && request.resource.data.uid == request.auth.uid
                    && isValidUsername(username);
      allow update: if isSignedIn()
                    && resource.data.uid == request.auth.uid
                    && request.resource.data.uid == request.auth.uid;
      allow delete: if isSignedIn() && resource.data.uid == request.auth.uid;
    }

    // Events (group drinking sessions with live leaderboard)
    // NOTE: the app's sharing model intentionally lets any signed-in user join an
    // event via a shared link, so participant updates are open to signed-in users.
    // Tightening this further (e.g. participant-only writes) requires storing a
    // flat participantIds array — see TODO in src/utils/events.js.
    match /events/{eventId} {
      function isEventCreator() {
        return isSignedIn() && resource.data.creator.uid == request.auth.uid;
      }

      allow read: if isSignedIn();
      // Creator info must match the authenticated user on create
      allow create: if isSignedIn()
                    && request.resource.data.creator.uid == request.auth.uid
                    && request.resource.data.title is string
                    && request.resource.data.title.size() > 0
                    && request.resource.data.title.size() <= 100;
      // Joining, inviting, status toggles and aggregate counters all mutate the
      // event doc; the creator identity must never change.
      allow update: if isSignedIn()
                    && request.resource.data.creator.uid == resource.data.creator.uid;
      allow delete: if isEventCreator();

      match /drinks/{drinkId} {
        allow read: if isSignedIn();
        // A user logs event drinks under their own uid, and the "tag a buddy"
        // flow also writes/deletes entries under the buddy's uid, so create and
        // delete stay open to signed-in users for now.
        // TODO: store the tagger's uid on event drink docs so delete can be
        // restricted to (owner || tagger || event creator).
        allow create, delete: if isSignedIn();
      }
    }
  }
}
